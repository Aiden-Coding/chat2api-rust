# ==========================================
# 1. 核心会话接口 (Chat Completions)
# ==========================================

### 发送会话请求 (非流式)
POST {{host}}/v1/chat/completions
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "model": "auto",
  "messages": [
    {
      "role": "user",
      "content": "Hello! How are you?"
    }
  ],
  "stream": false
}

### 发送会话请求 (流式)
POST {{host}}/v1/chat/completions
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "model": "auto",
  "messages": [
    {
      "role": "user",
      "content": "你现在是什么模型"
    }
  ],
  "stream": true
}

# ==========================================
# 2. Token 管理接口
# ==========================================

### 获取 Token 渲染页面 (HTML)
GET {{host}}/tokens

### 批量上传 Token
POST {{host}}/tokens/upload
Content-Type: application/x-www-form-urlencoded

text=your_token_1%0Ayour_token_2

### 清空 Token 列表
POST {{host}}/tokens/clear

### 获取错误 Token 列表
POST {{host}}/tokens/error

### 追加单个 Token
GET {{host}}/tokens/add/your_single_token_here

### 获取所有 Token 列表
GET {{host}}/tokens/list

### 批量/单个删除 Token
POST {{host}}/tokens/delete
Content-Type: application/json

{
  "tokens": [
    "your_token_to_delete_here"
  ]
}

# ==========================================
# 3. Grok 会话与 Token 管理接口
# ==========================================

### 发送 Grok 会话请求 (流式)
POST {{host}}/v1/chat/completions
Content-Type: application/json

{
  "model": "grok-4.3-console",
  "messages": [
    {
      "role": "user",
      "content": "Hello! How are you?"
    }
  ],
  "stream": true
}

### 发送 Grok 会话请求 (非流式)
POST {{host}}/v1/chat/completions
Content-Type: application/json

{
  "model": "grok-4.3-fast",
  "messages": [
    {
      "role": "user",
      "content": "Hello!"
    }
  ],
  "stream": false
}

### 发送 Grok 会话请求 (工具调用 - 包含 tools)
POST {{host}}/v1/chat/completions
Content-Type: application/json

{
  "model": "grok-4.3-fast",
  "messages": [
    {
      "role": "user",
      "content": "帮我查一下北京今天的天气如何？"
    }
  ],
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "get_current_weather",
        "description": "获取指定城市的当前天气情况",
        "parameters": {
          "type": "object",
          "properties": {
            "location": {
              "type": "string",
              "description": "城市名称，例如北京"
            }
          },
          "required": ["location"]
        }
      }
    }
  ],
  "tool_choice": "auto",
  "stream": true
}

### 获取所有 Grok Token 列表
GET {{host}}/grok_tokens/list

### 快速添加单个 Grok Token
GET {{host}}/grok_tokens/add/sso=YOUR_GROK_SSO_COOKIE

### 批量上传 Grok Tokens
POST {{host}}/grok_tokens/upload
Content-Type: application/x-www-form-urlencoded

text=sso=YOUR_GROK_SSO_COOKIE_1%0Asso=YOUR_GROK_SSO_COOKIE_2

### 批量删除 Grok Tokens
POST {{host}}/grok_tokens/delete
Content-Type: application/json

{
  "tokens": [
    "sso=YOUR_GROK_SSO_COOKIE_1"
  ]
}

### 清空所有 Grok Tokens
POST {{host}}/grok_tokens/clear

### 获取故障黑名单 Grok Tokens 列表
POST {{host}}/grok_tokens/error