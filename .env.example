# .env 文件配置示例

# 监听端口
PORT=5006

# 安全与授权码
API_PREFIX=
AUTHORIZATION=admin

# 网络与网关代理
CHATGPT_BASE_URL=https://chatgpt.com
PROXY_URL=
EXPORT_PROXY_URL=
CF_FILE_URL=

# 接口机制
HISTORY_DISABLED=true
RETRY_TIMES=3
ENABLE_LIMIT=true

# 浏览器指纹模拟 (用于绕过反机器人检测)
# 可选值: chrome120, chrome119, chrome116, safari17, edge101
# 推荐使用 chrome120 以获得最佳兼容性
IMPERSONATE=["chrome120"]

# User-Agent 列表 (可选，留空则使用默认)
USER_AGENTS=[]

# Cloudflare Clearance (用于绕过 Grok Web 模式反机器人检测)
# 获取方法：
# 1. 浏览器访问 https://grok.com
# 2. F12 打开开发者工具 → Application → Cookies
# 3. 复制 cf_clearance 的值粘贴到下面
# 注意: cf_clearance 有效期通常为几小时到几天，过期后需要重新获取
CF_CLEARANCE=Y2KOfB.lX4cv3AykBB9FSv42_6wHJcFAOu0Aue4U3m0-1783873262-1.2.1.1-LskrNjAuSDWj8wdoP4ICCvMOilEpuSj4.zUtzLwMNl4_Pkby2D27SJ7NA.4AUBwB1mDm1GOiqTzk_5vC1o2TbUo_v9h57OYDfOgae2BDtNywEGrpAVy8TQDeZwBy1usExo1zkSz9MjtbXmHNRfe_W_GPTgUSilLCJqPD6FmdFz.AuB4emH66z6ys.r8zkWPsmvgSZc3qqPzGOPXxLqp3_5KWrAGo2d8_YO46pMhxaABnDz0.nC7Lij340GkCAT9xZzFNtYJ8zG4ChFGBhWfWfhX0Cp5iLPzEyjvIWbRdzIxw2TlgSBdbe_Q3fXoKQsDG2JQ3BejoWtT079_ozxRmTQ
